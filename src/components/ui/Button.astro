---
/**
 * Button — the landing's call-to-action, rendered as an anchor.
 *
 * What: a themable link styled as a button in one of three variants. Why an
 * anchor and not a <button>: every CTA on this static page navigates — an
 * in-page anchor now, a `wa.me` deep-link once Phase 3 wires `whatsapp.ts` —
 * there are no form submits at this layer. Colors come from tokens only.
 *
 * @prop href - destination (anchor id or URL).
 * @prop variant - 'primary' (blue) | 'secondary' (outline, dark bg) | 'whatsapp' (green).
 * @prop size - 'md' (default, hero/section CTAs) | 'sm' (compact, header chrome).
 * @prop icon - optional leading IconKey.
 * @prop class - extra utilities (width/layout overrides).
 * @prop ...rest - extra anchor attributes (target, rel, data-*, aria-*).
 */
import type { IconKey } from '../../content/types';
import Icon from './Icon.astro';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'whatsapp';
  size?: 'md' | 'sm';
  icon?: IconKey;
  class?: string;
  [key: string]: unknown;
}

const { href, variant = 'primary', size = 'md', icon, class: className, ...rest } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-colors duration-base ease-standard';

const sizes: Record<NonNullable<Props['size']>, string> = {
  md: 'px-5 py-3 text-body',
  sm: 'px-4 py-2 text-small',
};

const variants: Record<NonNullable<Props['variant']>, string> = {
  primary: 'bg-blue-600 text-white hover:bg-blue-700',
  secondary: 'border border-border-dark text-text-on-dark hover:bg-navy-800',
  whatsapp: 'bg-whatsapp text-navy-900 hover:brightness-95',
};

const iconSize = size === 'sm' ? 'h-[18px] w-[18px]' : 'h-5 w-5';
---

<a href={href} class:list={[base, sizes[size], variants[variant], className]} {...rest}>
  {icon && <Icon name={icon} class={iconSize} />}
  <slot />
</a>
