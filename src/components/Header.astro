---
/**
 * Header — sticky top chrome shared by both locale pages.
 *
 * What: brand lockup, in-page navigation from `nav[]`, a static ES|EN locale
 * switch, and a WhatsApp CTA. On mobile the nav collapses into a native
 * <details> disclosure — keyboard-accessible and zero-JS — which Phase 3
 * replaces with the React mobile-nav + LanguageToggle islands (persistence,
 * no re-auto-redirect). Why static now: keeps the page shippable and a11y-clean
 * without shipping JS before the islands phase.
 *
 * @prop content - the active locale's content tree (nav, ui, contact).
 * @prop locale - active locale, drives the ES|EN active state.
 */
import type { Locale, SiteContent } from '../content/types';
import { pathForLocale, STORAGE_KEY } from '../lib/i18n';
import { whatsappNumber } from '../config/site.config';
import { waLink } from '../lib/whatsapp';
import logoRaw from '../assets/logo/nexora-logo-mono.svg?raw';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import LanguageToggle from './LanguageToggle.tsx';

interface Props {
  content: SiteContent;
  locale: Locale;
}

const { content, locale } = Astro.props;
const { nav, ui, contact } = content;

const logo = logoRaw
  .replace(/\s(width|height)="[^"]*"/g, '')
  .replace(/\scolor="[^"]*"/g, '');

const whatsappHref = waLink(whatsappNumber, contact.whatsappPrefill);
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
  <a
    href="#contenido"
    class="sr-only rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white focus:not-sr-only focus:absolute focus:left-4 focus:top-3 focus:z-[60]"
  >
    {ui.skipToContent}
  </a>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-2 md:px-6 md:py-3">
    <a
      href={pathForLocale(locale)}
      class="flex h-[2.25rem] items-center text-text-primary md:h-[2.75rem] [&>svg]:h-full [&>svg]:w-auto"
      set:html={logo}
    />

    <div class="flex items-center gap-6 lg:gap-9">
      <nav class="hidden items-center gap-6 md:flex" aria-label="Principal">
        {
          nav.map((item) => (
            <a
              href={`#${item.anchor}`}
              class="whitespace-nowrap text-small font-medium text-text-muted transition-colors hover:text-text-primary"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2 md:gap-3">
      <LanguageToggle
        client:idle
        locale={locale}
        esPath={pathForLocale('es')}
        enPath={pathForLocale('en')}
        storageKey={STORAGE_KEY}
        label={ui.switchLanguage}
      />

      <Button
        href={whatsappHref}
        variant="whatsapp"
        size="sm"
        icon="ui-whatsapp"
        class="hidden sm:inline-flex"
        target="_blank"
        rel="noopener noreferrer"
        data-analytics-cta="whatsapp"
        data-analytics-source="header"
      >
        {ui.stickyWhatsapp}
      </Button>

      <details class="group relative md:hidden">
        <summary
          class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-lg text-text-primary marker:hidden [&::-webkit-details-marker]:hidden"
          aria-label={ui.openMenu}
        >
          <Icon name="ui-menu" class="h-6 w-6" />
        </summary>
        <nav
          class="absolute right-0 mt-2 flex w-56 flex-col gap-1 rounded-xl border border-border bg-surface p-2 shadow-lg"
          aria-label="Móvil"
        >
          {
            nav.map((item) => (
              <a
                href={`#${item.anchor}`}
                class="rounded-lg px-3 py-2 text-body font-medium text-text-primary hover:bg-background"
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-cta="whatsapp"
            data-analytics-source="header_mobile"
            class="mt-1 rounded-lg bg-whatsapp px-3 py-2 text-center text-body font-semibold text-navy-900"
          >
            {contact.whatsappCtaLabel}
          </a>
        </nav>
      </details>
      </div>
    </div>
  </div>
</header>
