---
/**
 * Hero (section 01) — the above-the-fold value statement on a dark band.
 *
 * What: eyebrow location signal, the headline + subheadline, the primary and
 * secondary CTAs, and the own-products strip. Why dark: sets the page rhythm
 * (hero / process / contact are the dark bands per brand guidelines). The
 * primary CTA funnels to contact; the secondary jumps to the demos — there is
 * NO pricing anywhere. All copy comes from `hero` / `about.products`.
 *
 * @prop content - active locale content tree.
 */
import type { SiteContent } from '../../content/types';
import Button from '../ui/Button.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { hero, about, footer } = content;
---

<section
  id="inicio"
  class="relative overflow-hidden bg-gradient-to-br from-navy-700 to-navy-900 text-text-on-dark"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-9 md:px-6 md:py-10">
    <p class="text-caption font-semibold uppercase tracking-widest text-cyan">
      {footer.tagline}
    </p>

    <h1 class="max-w-3xl font-display text-h1 md:text-display">
      {hero.headline}
    </h1>

    <p class="max-w-2xl text-body-lg text-text-muted-dark">
      {hero.subheadline}
    </p>

    <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <Button href="#contacto" variant="whatsapp" icon="ui-whatsapp">
        {hero.ctaPrimary}
      </Button>
      <Button href="#demos" variant="secondary" icon="ui-arrow">
        {hero.ctaSecondary}
      </Button>
    </div>

    <div class="mt-6 flex flex-col gap-2 border-t border-border-dark pt-6">
      <p class="text-caption font-semibold uppercase tracking-widest text-text-muted-dark">
        {content.ui.productsLabel}
      </p>
      <p class="font-display text-body-lg font-semibold text-text-on-dark">
        {about.products.join('  ·  ')}
      </p>
    </div>
  </div>
</section>
