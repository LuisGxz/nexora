---
/**
 * Works / Demos (section 03) — ONLY Nexora's own work.
 *
 * What: the section header plus a grid of demo/project cards (preview, title,
 * client-type tag, result, and a "view demo" link when a live URL exists).
 * Preview: a real screenshot when `work.image` is set (lazy, fixed aspect so
 * CLS stays 0); otherwise, per brand imagery rules, a neutral token-colored
 * stripe with a mono label — never a fake illustration. Past employers never
 * appear here (they live in About as background).
 *
 * The "view demo" link renders only when the URL is real (not the `#`
 * placeholder still in `site.config.ts`), so there are no dead links pre-launch.
 *
 * @prop content - active locale content tree.
 */
import type { SiteContent } from '../../content/types';
import SectionEyebrow from '../ui/SectionEyebrow.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { works, sections, ui } = content;

/** A demo link is live only when a real URL is set (placeholders are `#`). */
const isLive = (url?: string): url is string => !!url && url !== '#';
---

<section id="demos" class="bg-background">
  <div class="mx-auto flex max-w-6xl flex-col gap-7 px-4 py-9 md:px-6">
    <SectionEyebrow header={sections.works} />

    <ul class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        works.map((work) => (
          <li class="flex flex-col overflow-hidden rounded-xl border border-border bg-surface shadow-sm transition-shadow duration-base ease-standard hover:shadow-md">
            <div
              class="relative flex aspect-video items-center justify-center border-b border-border"
              style="background: repeating-linear-gradient(45deg, var(--color-background) 0 6px, var(--color-border) 6px 8px);"
            >
              {work.image && (
                <img
                  src={work.image}
                  alt={work.title}
                  width="960"
                  height="540"
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-cover object-top"
                />
              )}
              <span class="relative rounded-full bg-surface/90 px-3 py-1 font-mono text-caption text-text-muted">
                {work.clientType}
              </span>
            </div>
            <div class="flex flex-1 flex-col gap-2 p-5">
              <h3 class="font-display text-h4 text-text-primary">{work.title}</h3>
              <p class="flex-1 text-small text-text-muted">{work.result}</p>
              {isLive(work.url) && (
                <a
                  href={work.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-small font-semibold text-blue transition-colors hover:text-blue-700"
                >
                  {ui.viewDemo}
                  <Icon name="ui-arrow" class="h-4 w-4" />
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
