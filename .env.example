# Nexora — environment variables (copy to `.env` for local, or set in Vercel).
# Only PUBLIC_* vars are exposed to the client build. No secrets live in the repo.

# Google Analytics 4 measurement id (format: G-XXXXXXXXXX).
# Optional: when unset, analytics is a no-op and ZERO analytics JS is shipped.
# Set it in Vercel → Project → Settings → Environment Variables for production.
PUBLIC_GA_ID=
