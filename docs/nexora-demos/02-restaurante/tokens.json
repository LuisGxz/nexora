{
  "demo": "02-restaurante",
  "brand": "La Sazón",
  "personality": "cálido, apetitoso, artesanal — tema claro",
  "color": {
    "bg": { "base": "#F6EFE3", "panel": "#FCF6EA", "card": "#FFFCF4", "inset": "#F0E7D6", "woodDark": "#221712", "overlay": "rgba(34,23,18,0.55)" },
    "ink": { "primary": "#2E211B", "secondary": "#6E5C51", "muted": "#9C8A7D", "inverse": "#F6EFE3", "onAccent": "#FBF3EA" },
    "accent": { "vino": "#7E2F35", "vinoHover": "#93393F", "vinoSoft": "rgba(126,47,53,0.10)", "dorado": "#B98A2F", "doradoLine": "rgba(185,138,47,0.45)" },
    "line": { "default": "#E7DCC8", "strong": "#D6C6A8", "dashed": "#DECFB4" },
    "feedback": { "success": "#3E7D4E", "error": "#B4372E", "warning": "#B98A2F", "whatsapp": "#1FAE55", "onWhatsapp": "#08240F" }
  },
  "font": {
    "display": { "family": "Playfair Display", "source": "Google Fonts", "weights": [500, 600, 700], "styles": ["normal", "italic"], "fallback": "Georgia, serif", "notes": "títulos y precios; itálica para acentos y el logotipo" },
    "body": { "family": "Karla", "source": "Google Fonts", "weights": [400, 500, 700], "fallback": "system-ui, sans-serif" },
    "mono": { "family": "ui-monospace", "source": "system", "fallback": "SFMono-Regular, Menlo, monospace", "notes": "eyebrows, chips, labels; uppercase + tracking .14–.2em" }
  },
  "typeScale": {
    "h1": "clamp(44px, 7vw, 84px) / 1.02 — Playfair 600",
    "h2": "clamp(32px, 4.6vw, 50px) / 1.05 — Playfair 600",
    "h3": "clamp(22px, 3vw, 28px) — Playfair 600",
    "price": "22px — Playfair 700, color vino",
    "body": "15.5px / 1.7 — Karla 400",
    "bodySm": "13.5px / 1.6 — Karla 400",
    "eyebrow": "11px, tracking .2em — mono uppercase, dorado",
    "chip": "10.5px, tracking .12em — mono uppercase"
  },
  "radius": { "chip": 999, "button": 6, "control": 8, "card": 12, "sheet": 16, "img": 10 },
  "shadow": {
    "card": "0 1px 2px rgba(46,33,27,0.05), 0 8px 24px -14px rgba(46,33,27,0.18)",
    "sheet": "0 -8px 40px -12px rgba(34,23,18,0.35)",
    "bar": "0 10px 30px -10px rgba(34,23,18,0.4)"
  },
  "spacing": { "unit": 4, "sectionY": "clamp(56px, 8vw, 104px)", "containerX": "clamp(18px, 4vw, 44px)", "containerMax": 1120, "menuMax": 980 },
  "ornament": { "divider": "línea 1px dorado 24px + rombo 7px dorado + línea — centrado bajo headers", "headerAlign": "centrado (vs. barbería alineada a la izquierda)" },
  "motion": { "hover": "sombra + translateY(-2px) .18s ease; links subrayado", "sheetIn": "slide-up + fade .3s ease", "spinner": "rotación .7s linear, borde vino" },
  "breakpoint": { "mobile": "< 768px", "strategy": "fluid auto-fit + clamp(); menú 1 col móvil / 2 col desktop" },
  "tailwind": {
    "theme": {
      "extend": {
        "colors": {
          "ls-bg": "#F6EFE3", "ls-panel": "#FCF6EA", "ls-card": "#FFFCF4", "ls-inset": "#F0E7D6",
          "ls-wood": "#221712", "ls-ink": "#2E211B", "ls-ink2": "#6E5C51", "ls-muted": "#9C8A7D",
          "ls-vino": "#7E2F35", "ls-dorado": "#B98A2F", "ls-line": "#E7DCC8",
          "ls-wa": "#1FAE55", "ls-error": "#B4372E", "ls-success": "#3E7D4E"
        },
        "fontFamily": {
          "display": ["Playfair Display", "Georgia", "serif"],
          "body": ["Karla", "system-ui", "sans-serif"],
          "mono": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
        },
        "borderRadius": { "btn": "6px", "ctrl": "8px", "card": "12px", "sheet": "16px" },
        "maxWidth": { "shell": "1120px", "menu": "980px" }
      }
    }
  }
}
