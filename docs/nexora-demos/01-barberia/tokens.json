{
  "demo": "01-barberia",
  "brand": "Bravo Barber Co.",
  "personality": "oscuro, masculino, industrial",
  "color": {
    "bg": {
      "base": "#0E0D0B",
      "raised": "#121110",
      "card": "#15130F",
      "cardAlt": "#17150F",
      "inset": "#0F0D0A",
      "input": "#0E0C0A",
      "footer": "#0B0A08"
    },
    "ink": {
      "primary": "#F2EDE6",
      "secondary": "#B7AFA4",
      "muted": "#877F73",
      "faint": "#5E584F",
      "onAccent": "#14100B"
    },
    "accent": {
      "copper": "#C87F3F",
      "copperSoft": "rgba(200,127,63,0.12)",
      "copperStripe": "rgba(200,127,63,0.05)",
      "copperGlow": "rgba(200,127,63,0.15)",
      "copperLine": "rgba(200,127,63,0.35)",
      "amber": "#E0A24E"
    },
    "line": {
      "default": "rgba(242,237,230,0.10)",
      "input": "rgba(242,237,230,0.15)",
      "strong": "rgba(242,237,230,0.25)",
      "dashed": "rgba(242,237,230,0.14)"
    },
    "feedback": {
      "success": "#4CAF6E",
      "error": "#E05B4E",
      "warning": "#E0A24E",
      "whatsapp": "#22C15E",
      "onWhatsapp": "#06220F"
    }
  },
  "font": {
    "display": { "family": "Bebas Neue", "source": "Google Fonts", "weights": [400], "fallback": "Impact, sans-serif", "notes": "titulares, precios, botones; siempre uppercase, letter-spacing .02–.08em" },
    "body": { "family": "Inter", "source": "Google Fonts", "weights": [400, 500, 600, 700], "fallback": "system-ui, sans-serif" },
    "mono": { "family": "ui-monospace", "source": "system", "fallback": "SFMono-Regular, Menlo, monospace", "notes": "eyebrows, chips, labels técnicos; uppercase + letter-spacing .1–.2em" }
  },
  "typeScale": {
    "h1": "clamp(58px, 10vw, 116px) / 0.92 — Bebas Neue",
    "h2": "clamp(38px, 5.4vw, 58px) / 0.95 — Bebas Neue",
    "h3": "clamp(26px, 4vw, 34px) — Bebas Neue",
    "priceCard": "30px — Bebas Neue",
    "stat": "32px — Bebas Neue",
    "body": "15px / 1.65 — Inter 400",
    "bodySm": "13.5px / 1.55 — Inter 400",
    "eyebrow": "11px, letter-spacing .2em — mono uppercase",
    "chip": "10.5px, letter-spacing .12em — mono uppercase",
    "legal": "10px, letter-spacing .1em — mono uppercase"
  },
  "radius": { "chip": 3, "button": 4, "control": 6, "card": 8, "panel": 10, "circle": 999 },
  "shadow": {
    "float": "0 8px 24px rgba(0,0,0,0.5)",
    "none": "las cards no llevan sombra; jerarquía por borde 1px + cambio de fondo"
  },
  "spacing": { "unit": 4, "sectionY": "clamp(56px, 8vw, 100px)", "containerX": "clamp(18px, 4vw, 44px)", "containerMax": 1160, "bookingMax": 880, "cardGap": 14 },
  "texture": {
    "placeholder": "repeating-linear-gradient(45deg, transparent 0 9px, rgba(200,127,63,0.05) 9px 10px) sobre #14120F, borde 1px dashed",
    "heroGlow": "radial-gradient(900px 420px at 85% -10%, rgba(200,127,63,0.15), transparent 62%)"
  },
  "motion": {
    "hover": "border-color/brightness .15s ease; cards translateY(-2px)",
    "stepIn": "fade + translateY(8px), .28s ease",
    "spinner": "rotación .7s linear infinite"
  },
  "breakpoint": { "mobile": "< 768px (nav colapsa a logo + CTA)", "strategy": "fluid: grids auto-fit + clamp(); sin media queries duras" },
  "tailwind": {
    "theme": {
      "extend": {
        "colors": {
          "bb-bg": "#0E0D0B",
          "bb-raised": "#121110",
          "bb-card": "#15130F",
          "bb-inset": "#0F0D0A",
          "bb-ink": "#F2EDE6",
          "bb-ink2": "#B7AFA4",
          "bb-muted": "#877F73",
          "bb-copper": "#C87F3F",
          "bb-amber": "#E0A24E",
          "bb-wa": "#22C15E",
          "bb-error": "#E05B4E",
          "bb-success": "#4CAF6E"
        },
        "fontFamily": {
          "display": ["Bebas Neue", "Impact", "sans-serif"],
          "body": ["Inter", "system-ui", "sans-serif"],
          "mono": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
        },
        "borderRadius": { "chip": "3px", "btn": "4px", "ctrl": "6px", "card": "8px", "panel": "10px" },
        "maxWidth": { "shell": "1160px", "booking": "880px" }
      }
    }
  }
}
