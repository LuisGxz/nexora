{
  "demo": "05-pyme",
  "brand": "Vértice Consultores",
  "personality": "corporativo, sobrio, confiable — B2B",
  "color": {
    "bg": { "base": "#F8FAFC", "panel": "#EEF2F7", "card": "#FFFFFF", "navy": "#12294A", "navyDeep": "#0C1D36" },
    "ink": { "primary": "#101C2C", "secondary": "#44546A", "muted": "#7A8AA0", "inverse": "#EDF2F9", "onAccent": "#F4F8FF" },
    "accent": { "azul": "#1C4FA0", "azulHover": "#2560BE", "azulSoft": "rgba(28,79,160,0.08)", "cielo": "#3E7BC4" },
    "line": { "default": "#DCE3EC", "strong": "#C3CEDC", "dashed": "#CDD7E3" },
    "feedback": { "success": "#2E7D52", "error": "#B83A3A", "whatsapp": "#1FAE55", "onWhatsapp": "#08240F" }
  },
  "font": {
    "display": { "family": "Space Grotesk", "source": "Google Fonts", "weights": [500, 700], "fallback": "system-ui, sans-serif", "notes": "títulos y cifras" },
    "body": { "family": "Inter", "source": "Google Fonts", "weights": [400, 500, 600], "fallback": "system-ui, sans-serif" },
    "label": { "notes": "eyebrows: Space Grotesk 500 11px uppercase tracking .16em azul" }
  },
  "typeScale": {
    "h1": "clamp(38px, 5.6vw, 64px) / 1.05 — Space Grotesk 700",
    "h2": "clamp(28px, 4vw, 42px) / 1.1 — Space Grotesk 700",
    "h3": "19–22px — Space Grotesk 500",
    "stat": "clamp(32px, 4vw, 44px) — Space Grotesk 700 azul",
    "body": "15px / 1.7 — Inter 400",
    "bodySm": "13.5px / 1.6",
    "eyebrow": "11px uppercase tracking .16em — Space Grotesk 500 azul"
  },
  "radius": { "chip": 6, "button": 8, "control": 8, "card": 12, "panel": 14 },
  "shadow": { "card": "0 1px 2px rgba(16,28,44,0.04), 0 10px 28px -18px rgba(16,28,44,0.22)", "none": "secciones separadas por fondos alternos base/panel, no por sombras fuertes" },
  "spacing": { "unit": 4, "sectionY": "clamp(56px, 8vw, 100px)", "containerX": "clamp(18px, 4vw, 44px)", "containerMax": 1140, "formMax": 720 },
  "motifs": { "logo": "triángulo simple (▲) azul + 'VÉRTICE' Space Grotesk 700 + 'CONSULTORES' spaced", "proceso": "timeline 4 pasos numerados 01–04, línea azul", "clientes": "wordmarks tipográficos ficticios en gris (no logos)", "headerAlign": "izquierda" },
  "motion": { "hover": "borde azul + translateY(-2px) .18s", "formSend": "loading 'Enviando…' 800ms → éxito", "counterUp": "no (sobrio)" },
  "breakpoint": { "mobile": "< 768px", "strategy": "fluid auto-fit + clamp(); proceso vertical en móvil" },
  "tailwind": {
    "theme": {
      "extend": {
        "colors": {
          "vx-bg": "#F8FAFC", "vx-panel": "#EEF2F7", "vx-card": "#FFFFFF", "vx-navy": "#12294A",
          "vx-ink": "#101C2C", "vx-ink2": "#44546A", "vx-muted": "#7A8AA0",
          "vx-azul": "#1C4FA0", "vx-cielo": "#3E7BC4", "vx-line": "#DCE3EC",
          "vx-wa": "#1FAE55", "vx-error": "#B83A3A", "vx-success": "#2E7D52"
        },
        "fontFamily": {
          "display": ["Space Grotesk", "system-ui", "sans-serif"],
          "body": ["Inter", "system-ui", "sans-serif"]
        },
        "borderRadius": { "btn": "8px", "card": "12px", "panel": "14px" },
        "maxWidth": { "shell": "1140px", "form": "720px" }
      }
    }
  }
}
