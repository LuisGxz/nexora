{
  "demo": "03-consultorio",
  "brand": "Clínica Dental Aurora",
  "personality": "limpio, confiable, médico premium — tema claro frío",
  "color": {
    "bg": { "base": "#FAFCFC", "panel": "#F1F7F8", "card": "#FFFFFF", "mint": "#DDF1EC", "sky": "#E3F1F6", "navy": "#123A47" },
    "ink": { "primary": "#17303B", "secondary": "#4E6B77", "muted": "#7E97A1", "inverse": "#F2FAFB", "onAccent": "#F2FAFB" },
    "accent": { "teal": "#0E7490", "tealHover": "#0F82A2", "tealSoft": "rgba(14,116,144,0.08)", "mintDeep": "#159580" },
    "line": { "default": "#DFE9EC", "strong": "#C4D6DC", "dashed": "#CFE0E5" },
    "feedback": { "success": "#2E8B57", "error": "#C2453A", "warning": "#C08A2D", "whatsapp": "#1FAE55", "onWhatsapp": "#08240F" }
  },
  "font": {
    "display": { "family": "DM Sans", "source": "Google Fonts", "weights": [500, 700], "fallback": "system-ui, sans-serif", "notes": "títulos 700, tracking -0.01em" },
    "body": { "family": "DM Sans", "source": "Google Fonts", "weights": [400, 500], "fallback": "system-ui, sans-serif" },
    "label": { "family": "DM Sans", "weights": [700], "notes": "eyebrows: 11px uppercase tracking .18em color teal (sin mono: registro médico, no industrial)" }
  },
  "typeScale": {
    "h1": "clamp(40px, 6vw, 68px) / 1.06 — DM Sans 700",
    "h2": "clamp(30px, 4.2vw, 44px) / 1.1 — DM Sans 700",
    "h3": "20–24px — DM Sans 700",
    "body": "15.5px / 1.7 — DM Sans 400",
    "bodySm": "13.5px / 1.6",
    "eyebrow": "11px uppercase tracking .18em — DM Sans 700 teal",
    "priceCard": "26px DM Sans 700 teal"
  },
  "radius": { "chip": 999, "button": 10, "control": 10, "card": 14, "panel": 18 },
  "shadow": {
    "card": "0 1px 2px rgba(23,48,59,0.04), 0 10px 30px -18px rgba(23,48,59,0.25)",
    "cta": "0 6px 18px -8px rgba(14,116,144,0.45)"
  },
  "spacing": { "unit": 4, "sectionY": "clamp(56px, 8vw, 104px)", "containerX": "clamp(18px, 4vw, 44px)", "containerMax": 1120, "wizardMax": 860 },
  "motifs": { "logo": "cruz simple (2 rectángulos redondeados) teal + wordmark 'Aurora' DM Sans 700", "chips": "pills menta/cielo con texto navy", "headerAlign": "izquierda con eyebrow teal" },
  "motion": { "hover": "sombra + translateY(-2px) .18s", "stepIn": "fade+slide .28s", "accordion": "max-height .25s ease", "spinner": "borde teal .7s linear" },
  "breakpoint": { "mobile": "< 768px", "strategy": "fluid auto-fit + clamp()" },
  "tailwind": {
    "theme": {
      "extend": {
        "colors": {
          "au-bg": "#FAFCFC", "au-panel": "#F1F7F8", "au-card": "#FFFFFF", "au-mint": "#DDF1EC", "au-sky": "#E3F1F6",
          "au-navy": "#123A47", "au-ink": "#17303B", "au-ink2": "#4E6B77", "au-muted": "#7E97A1",
          "au-teal": "#0E7490", "au-line": "#DFE9EC", "au-wa": "#1FAE55", "au-error": "#C2453A", "au-success": "#2E8B57"
        },
        "fontFamily": { "sans": ["DM Sans", "system-ui", "sans-serif"] },
        "borderRadius": { "btn": "10px", "card": "14px", "panel": "18px" },
        "maxWidth": { "shell": "1120px", "wizard": "860px" }
      }
    }
  }
}
